<DeletePasswordWindow>:
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            pos: self.pos
            size: self.size
    Image:
        source: 'background_files/tech1.jpg'
        #size_hint: None,None
        size: self.size
        width: dp(1000)
        color: (1,1,1,0.7)
        allow_stretch: True
        keep_ratio: False
    GridLayout:
        spacing: 30
        padding: 40,10
        cols:1
        GridLayout:
            cols: 2

            Image:
                source:'LOGO-TECH PROGRAM.jpg'
                size_hint:None,None
                height: dp(180)
                width: dp(180)
            Label:
                text: 'LE FORM  VENTURA  GLOBAL LLP'
                color:0,0,0,0.5
                bold: True
                font_size:50

        Label:
            size_hint: None, None
        MDFillRoundFlatIconButton:
            text: 'Back'
            size_hint:None, None
            icon: 'arrow-left-circle'
            height: dp(40)
            width: dp(100)
            #background_color: 1, 165/255, 0, 0.2
            color: 1, 168/255, 0, 1
            #background_normal: ''
            on_press:
                root.ids.password.text = ''
                root.manager.current = 'OpeningWindow'
                root.manager.transition.direction = 'right'
                root.parent.get_screen('SearchWindow').ids.registration_no.text = ''
        Label:
            text: 'DELETE ACCESS PAGE'
            color: 0,0,0,1
            font_size: dp(25)
            bold: True
            size_hint: 1,None


            canvas.before:
                Color:
                    rgba: 1,1,1,1
                Line:

                    width: 5
                    rectangle: self.x, self.y, self.width, self.height
        Label:
            size_hint: None,None
        GridLayout:
            cols:3
            Label:
                size_hint: None,None
                width: dp(200)
            MDTextField:
                id: password
                text: ''
                hint_text: 'Password'
                mode: 'fill'
                fill_color_normal: 1,1,1,1
                size_hint: 0.5, None
                height: dp(30)
                multiline: False
                icon_right: 'key-variant'
            Label:
                size_hint: None,None
                width: dp(200)
        GridLayout:
            cols:3
            Label:
                size_hint: 1, None
            MDFillRoundFlatIconButton:
                text:'Delete'
                icon: 'delete'
                size_hint: 1, None
                height: 70
                md_bg_color: 1,0,0,1
                #background_normal: ''
                pos_hint: {'center_x':0.5}
                on_press: root.password_check()
            Label:
                size_hint: 1, None


        Label:
            size_hint: 1, None
            height: 100


<OpeningPasswordWindow>:
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            pos: self.pos
            size: self.size
    GridLayout:
        spacing: 30
        padding: 40,10
        cols:1
        GridLayout:
            cols: 2

            Image:
                source:'LOGO-TECH PROGRAM.jpg'
                size_hint:None,None
                height: dp(180)
                width: dp(180)
                allow_stretch: True
            Label:
                text: 'LE FORM  VENTURA  GLOBAL LLP'
                color:0,0,0,0.5
                bold: True
                font_size:50

        Label:
            size_hint: None, None
            height: dp(100)


        Label:
            size_hint: 1, None
            height: dp(30)
        GridLayout:
            cols:3
            Label:

            MDTextField:
                id: password
                password: True
                hint_text: 'Password'
                icon_right: 'key-variant'
                pos_hint: {'center_x':0.5}
                size_hint: None,None
                width: dp(500)
                on_text_validate: root.enter()

            Label:

        GridLayout:
            cols:4
            Label:

            MDCheckbox:
                size_hint: None,None
                #width: dp(30)
                #height: dp(30)
                on_press: password.password = False if password.password == True else True
            MDLabel:
                text: '[ref=Show Password]Show Password[/ref]'
                markup: True
                size_hint: 1,None
            Label:

        Label:
            size_hint: 1, None
            height: dp(100)
        GridLayout:
            cols:3

            Label:
                size_hint: None, None
            MDFillRoundFlatIconButton:
                #style: "elevated"
                icon: 'account-arrow-right-outline'
                text:'Access'
                #background_color: 1,0,0,1
                size_hint: 1, None
                #height: 70
                #background_normal: ''
                pos_hint: {'center_x':0.5}
                on_press: root.enter()
            Label:
                size_hint: None, None


        Label:
            size_hint: 1, None
            height: dp(100)


<ChangePasswordWindow>:
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            pos: self.pos
            size: self.size
    GridLayout:
        spacing: 30
        padding: 40,10
        cols:1
        GridLayout:
            cols: 2

            Image:
                source:'LOGO-TECH PROGRAM.jpg'
                size_hint:None,None
                height: dp(180)
                width: dp(180)
            Label:
                text: 'LE FORM  VENTURA  GLOBAL LLP'
                color:0,0,0,0.5
                bold: True
                font_size:50

        Label:
            size_hint: None, None
        MDFillRoundFlatIconButton:
            text: 'Back'
            size_hint:None, None
            icon: 'arrow-left-circle'
            height: dp(40)
            width: dp(100)

            on_press:
                root.back()
                #root.manager.current = 'OpeningWindow'
                #root.manager.transition.direction = 'right'
        Label:
            text: 'CHANGE PASSWORD PAGE'
            color: 0,0,0,1
            font_size: dp(25)
            bold: True
            size_hint: 1,None


            canvas.before:
                Color:
                    rgba: 1,165/255,0,1
                Line:

                    width: 5
                    rectangle: self.x, self.y, self.width, self.height
        GridLayout:
            cols:2

            MDTextField:
                id: old_password
                text: ''
                hint_text: 'Old Password'
                mode: 'fill'
                fill_color_normal: 1,1,1,1
                size_hint: 0.5, None
                height: dp(30)
                multiline: False
                icon_right: 'key-variant'

            MDTextField:
                id: new_password
                text: ''
                hint_text: 'New Password'
                mode: 'fill'
                fill_color_normal: 1,1,1,1
                size_hint: 0.5, None
                height: dp(30)
                multiline: False
                icon_right: 'key-variant'
                on_text: self.text = self.text.replace(' ', '')

        GridLayout:
            cols:3
            Label:
                size_hint: None, None
            MDFillRoundFlatIconButton:
                text: 'Change Password'
                size_hint:1, None
                icon: 'key-change'
                height: dp(40)
                width: dp(100)
                md_bg_color: 0,0.7,0,1
                on_press: root.change_password()
            Label:
                size_hint: None, None

        Label:
            size_hint: 1, None
            height: 100

<AdministrativeWindow>:
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            pos: self.pos
            size: self.size
    Image:
        source: 'background_files/tech1.jpg'
        #size_hint: None,None
        size: self.size
        width: dp(1000)
        color: (1,1,1,0.7)
        allow_stretch: True
        keep_ratio: False
    GridLayout:
        spacing: 30
        padding: 40,30
        rows: 4
        GridLayout:
            cols: 2

            Image:
                source:'LOGO-TECH PROGRAM.jpg'
                size_hint:None,None
                height: dp(180)
                width: dp(180)
            Label:
                text: 'LE FORM  VENTURA  GLOBAL LLP'
                color:0,0,0,0.5
                bold: True
                font_size:50
        Label:
            size_hint: None,None
            height: dp(160)
        MDFillRoundFlatIconButton:
            text: 'Back'
            size_hint:None, None
            icon: 'arrow-left-circle'
            height: dp(40)
            width: dp(100)
            #background_color: 1, 165/255, 0, 0.2
            color: 1, 168/255, 0, 1
            #background_normal: ''
            on_press:
                root.manager.current = 'OpeningWindow'
                root.manager.transition.direction = 'right'

        Label:
            size_hint: None,None
            height: dp(500)

    BoxLayout:
        spacing: 50
        orientation: 'vertical'

        MDFillRoundFlatIconButton:
            text: 'Existing Share Holder'
            font_size: 30
            icon: 'account-edit-outline'
            #md_bg_color: (1,165/255,0,1)
            bold: True
            size_hint: 0.75,None
            height: dp(60)
            pos_hint: {'center_x': 0.5}
            on_press:
                root.manager.current = 'SearchWindow'
                root.manager.transition.direction = 'left'
                root.set_call_page(True)

        MDFillRoundFlatIconButton:
            text: 'Change Password'
            font_size: 30
            icon: 'shield-key-outline'
            #md_bg_color: (1,165/255,0,1)
            bold: True
            size_hint: 0.75,None
            height: dp(60)
            pos_hint: {'center_x': 0.5}
            on_press:
                root.manager.current = 'ChangePasswordWindow'
                root.manager.transition.direction = 'left'

        Label:
            size_hint: 1,None
            height: dp(1)


<PasswordDialogView>:
    size_hint: 1, None
    height: dp(150)
    BoxLayout:
        orientation: 'vertical'

        Label:
            size_hint: 1,None
            text: 'Please Enter Your Password To Access The Administration Page'
            color: 0.5,0.5,0.5,1
            pos_hint: {'x':0}
        BoxLayout:
            MDTextField:
                id: admin_password
                password: True
                hint_text: 'Password'
                size_hint: 1,None
                #on_text: root.password_update(self.text)
            MDIconButton:
                id: eye_icon
                icon: "eye-off"
                #pos_hint: {"y": .5}
                pos: admin_password.width - self.width + dp(8), 0
                theme_text_color: "Hint"
                on_release:
                    self.icon = "eye" if self.icon == "eye-off" else "eye-off"
                    admin_password.password = False if admin_password.password is True else True

<RoundedButton@Button>:
    background_color: (0,0,0,0)
    background_normal:''
    canvas.before:
        Color:
            rgba: (1,165/255,0,1) if self.state == 'normal' else (1,190/255,0,1)
        RoundedRectangle:
            size: self.size
            pos: self.pos
            radius: [18]


<RoundedButton1@Button>:
    background_color: (0,0,0,0)
    background_normal:''
    canvas.before:
        Color:
            rgba: (1,165/255,0,0.1) if self.state == 'normal' else (1,165/255,0,0.3)
        RoundedRectangle:
            size: self.size
            pos: self.pos
            radius: [25]

<RoundedButton2@Button>:
    background_color: (0,0,0,0)
    background_normal:''
    canvas.before:
        Color:
            rgba: (1,0,0,1) if self.state == 'normal' else (1,0,0,0.3)
        RoundedRectangle:
            size: self.size
            pos: self.pos
            radius: [25]


<RoundedButton3@Button>:
    background_color: (0,0,0,0)
    background_normal:''
    canvas.before:
        Color:
            rgba: (0,0.7,0,1) if self.state == 'normal' else (0,0.7,0,0.7)
        RoundedRectangle:
            size: self.size
            pos: self.pos
            radius: [25]

