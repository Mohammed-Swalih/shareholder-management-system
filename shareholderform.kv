OpeningPasswordWindow:

<RegistrationWindow>:
    GridLayout:
        cols: 1
        BoxLayout:
            size_hint: 1,None
            height: dp(180)
            canvas.before:
                Color:
                    rgba: 1, 1, 1, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
                    source: 'background_files/white.jpg'
            Image:
                source:'company_logo.png'
                size_hint:None,None
                height: dp(180)
                width: dp(180)
            Label:
                text: 'LE FORM  VENTURA  GLOBAL LLP'
                color:0,0,0,0.7
                bold: True
                font_size:50

        ScrollView:
            id: scroll_view_registration
            canvas.before:
                Color:
                    rgba: 1, 1, 1, 0.7
                Rectangle:
                    pos: self.pos
                    size: self.size
                    source: 'background_files/tech.jpg'

            GridLayout:
                size_hint: 1, None
                height: self.minimum_height
                cols:1
                spacing: 70
                padding:40,30

                GridLayout:
                    cols: 1
                    MDFillRoundFlatIconButton:
                        text: 'Back'
                        size_hint:None, None
                        icon: 'arrow-left-circle'
                        height: dp(40)
                        width: dp(100)
                        #background_color: 1, 165/255, 0, 0.2
                        color: 1, 168/255, 0, 1
                        #background_normal: ''
                        on_press:
                            root.manager.current = 'OpeningWindow'
                            root.manager.transition.direction = 'right'
                Label:
                    text: 'SHAREHOLDER REGISTRATION FORM'
                    color: 0,0,0,1
                    font_size: dp(25)
                    bold: True
                    size_hint: 1,None
                    height: dp(70)


                Label:
                    text: 'Section 1: SHAREHOLDER DETAILS'
                    color: 0,0,0,1
                    font_size: dp(20)
                    size_hint: 0.5,None
                    height: dp(1)
                    bold: True


                MDTextField:
                    id: first_name
                    hint_text: 'First Name'
                    mode: 'fill'
                    max_text_length: 30
                    fill_color_normal: 1,1,1,1
                    on_focus:
                        self.required = True
                    text: ''
                    size_hint: 0.5, None
                    height: dp(55)
                    background_color: 255/255,163/255,0,0.2
                    multiline: False


                MDTextField:
                    id: surname
                    hint_text: 'Surname/Family name'
                    mode: 'fill'
                    max_text_length: 30
                    fill_color_normal: 1,1,1,1
                    on_focus:
                        self.required = True
                    text: ''
                    size_hint: 0.5, None
                    height: dp(55)
                    background_color: 255/255,163/255,0,0.2
                    multiline: False

                Label:
                    text: 'Gender:'
                    color: 0,0,0,1
                    font_size: dp(19)
                    size_hint: 0.5, None
                    height:dp(1)
                    bold: True
                GridLayout:
                    cols: 5
                    Label:
                        size_hint: None,None
                        width: dp(480)
                    Label:
                        text: 'Male:'
                        color: 0,0,0,1
                        font_size: dp(16)
                        size_hint: None, None
                        #height:dp(1)
                        bold: True
                    MDCheckbox:
                        id: male_checkbox
                        size_hint: None,None
                        on_press: root.male_checkbox(self)
                    Label:
                        text: 'Female:'
                        color: 0,0,0,1
                        font_size: dp(16)
                        size_hint: None, None
                        #height:dp(1)
                        bold: True
                    MDCheckbox:
                        id: female_checkbox
                        size_hint: None,None
                        on_press: root.female_checkbox(self)
                Label:
                    size_hint: 1,None
                    height: dp(20)


                MDTextField:
                    id: date_of_birth
                    hint_text: 'Date of Birth'
                    mode: 'fill'
                    max_text_length: 10
                    fill_color_normal: 1,1,1,1
                    on_focus:
                        self.required = True
                    text: ''
                    size_hint: 0.5, None
                    height: dp(55)
                    background_color: 255/255,163/255,0,0.2
                    multiline: False
                    on_text: self.text = self.text.replace(' ','')
                    helper_text: 'DD/MM/YYYY'
                    validator: 'date'
                    date_format: 'dd/mm/yyyy'
                    date_interval: "01/01/1900", None

                MDTextField:
                    id: postal_address
                    hint_text: 'Postal Address'
                    text: ''
                    mode: 'fill'
                    max_text_length: 120
                    fill_color_normal: 1,1,1,1
                    on_focus:
                        self.required = True
                    size_hint: 0.5, None
                    height: dp(55)
                    multiline: False

                MDTextField:
                    id: post_code
                    hint_text: 'Post Code'
                    mode: 'fill'
                    max_text_length: 120
                    fill_color_normal: 1,1,1,1
                    on_focus:
                        self.required = True
                    size_hint: 0.5, None
                    height: dp(55)
                    multiline: False
                    on_text: self.text = self.text.replace(' ','')

                Label:
                    text: 'Mobile phone no:'
                    color: 0,0,0,1
                    bold: True
                    font_size: dp(19)
                    size_hint: 0.5, None
                    height:dp(1)



                GridLayout:
                    cols: 3
                    MDTextField:
                        id: mobile_phone_no_india
                        hint_text: 'India'
                        mode: 'fill'
                        max_text_length: 13
                        helper_text: 'Eg: +910123456789'
                        fill_color_normal: 1,1,1,1
                        on_focus:
                            self.required = True
                        size_hint: 0.5, None
                        height: dp(55)
                        multiline: False
                        on_text: self.text = self.text.replace(' ','')
                    Label:
                        size_hint: None,None
                    MDTextField:
                        id: mobile_phone_no_abroad
                        hint_text: 'Work Place'
                        mode: 'fill'
                        max_text_length: 15
                        helper_text: 'Eg: +(Country Code)0123456789'
                        fill_color_normal: 1,1,1,1
                        on_focus:
                            self.required = True
                        size_hint: 0.5, None
                        height: dp(55)
                        multiline: False
                        on_text: self.text = self.text.replace(' ','')
                Label:
                    size_hint: 1, None

                MDTextField:
                    id: iqama_ref
                    hint_text: 'IQAMA REF#'
                    mode: 'fill'
                    max_text_length: 15
                    fill_color_normal: 1,1,1,1
                    on_focus:
                        self.required = True
                    size_hint: 0.5, None
                    height: dp(55)
                    multiline: False
                    on_text: self.text = self.text.replace(' ','')


                MDTextField:
                    id: passport_ref
                    hint_text: 'Passport Ref#'
                    mode: 'fill'
                    max_text_length: 15
                    fill_color_normal: 1,1,1,1
                    on_focus:
                        self.required = True
                    size_hint: 0.5, None
                    height: dp(55)
                    multiline: False
                    on_text: self.text = self.text.replace(' ','')

                MDTextField:
                    id: email_address
                    hint_text: 'Email Address'
                    mode: 'fill'
                    max_text_length: 30
                    helper_text: 'user@gmail.com'
                    fill_color_normal: 1,1,1,1
                    on_focus:
                        self.required = True
                    size_hint: 0.5, None
                    height: dp(55)
                    multiline: False
                    on_text: self.text = self.text.replace(' ','')
                    validator: "email"

                MDTextField:
                    id: work_place
                    hint_text: 'Work Place'
                    mode: 'fill'
                    max_text_length: 30
                    fill_color_normal: 1,1,1,1
                    on_focus:
                        self.required = True
                    size_hint: 0.5, None
                    height: dp(55)
                    multiline: False
                Label:
                    text: 'Installment Details:'
                    color: 0,0,0,1
                    font_size: dp(19)
                    bold: True
                    size_hint: 0.5, None
                    height:dp(1)
                Label:
                    text: 'NOTE: Please Press Enter After Entering The Amount To See Total'
                    color: 1,0,0,1
                    font_size: dp(17)
                    bold: True
                    size_hint: 0.5, None
                    height:dp(1)
                GridLayout:
                    spacing: 40
                    cols: 12
                    Label:
                        size_hint: 1,None
                        height:dp(1)
                    Label:
                        text: '1'
                        size_hint:1,None
                        height: dp(1)
                        color: 0,0,0,1
                        font_size: dp(19)
                    Label:
                        text: '2'
                        size_hint:1,None
                        height: dp(1)
                        color: 0,0,0,1
                        font_size: dp(19)
                    Label:
                        text: '3'
