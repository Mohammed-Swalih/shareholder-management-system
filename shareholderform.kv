                        height: dp(1)
                        color: 0,0,0,1
                        font_size: dp(19)
                    Label:
                        id: total_amount
                        text: 'Total'
                        size_hint:None,None
                        height: dp(1)
                        width: dp(10)
                        bold: True
                        color: 1,1,1,1
                        font_size: dp(19)
                    GridLayout:
                        rows:3
                        Label:
                        Label:
                            text: 'Amount:'
