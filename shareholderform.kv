                        size_hint: 0.5, None
                        height: dp(30)
                        background_color: 1,1,1,1
                        multiline: False
                    TextInput:
                        id: percentage_3
                        text: ''
                        size_hint: 0.5, None
                        height: dp(30)
                        background_color: 1,1,1,1
                        multiline: False
                        on_text:
                            self.text = self.text.replace(' ','')
                            root.add_percentage3_sign(self.text)
                    Label:
                        text: '4.'
                        color: 0,0,0,1
                        font_size: dp(19)
                        size_hint: None, None
                        width: dp(10)
                        height:dp(10)
                    TextInput:
                        id: name_4
                        text: ''
                        hint_text: '4.'
                        size_hint: 0.5, None
                        height: dp(30)
                        background_color: 1,1,1,1
                        multiline: False
                    TextInput:
                        id: relation_4
                        text: ''
                        size_hint: 0.5, None
                        height: dp(30)
                        background_color: 1,1,1,1
                        multiline: False
                    TextInput:
                        id: percentage_4
                        text: ''
                        size_hint: 0.5, None
                        height: dp(30)
                        background_color: 1,1,1,1
                        multiline: False
                        on_text:
                            self.text = self.text.replace(' ','')
                            root.add_percentage4_sign(self.text)
                Label:
                    size_hint: 1,None
                    height: dp(70)

                MDTextField:
                    id: other_details
                    text: ''
                    hint_text: 'Other Details If Any'
                    mode: 'fill'
                    max_text_length: 120
                    fill_color_normal: 1,1,1,1
                    on_focus:
                        self.required = True
                    size_hint: 0.5, None
                    height: dp(55)
                    multiline: False

                MDTextField:
                    id: suggested_by
                    text: ''
                    hint_text: 'Suggested By'
                    mode: 'fill'
                    max_text_length: 50
                    fill_color_normal: 1,1,1,1
                    on_focus:
                        self.required = True
                    size_hint: 0.5, None
                    height: dp(55)
                    multiline: False

                GridLayout:
                    cols:3
                    Label:
                        size_hint: None, None
                    MDFillRoundFlatIconButton:
                        text:'ADD SHAREHOLDER'
                        icon: 'plus-circle-outline'
                        size_hint: 1, None
                        height: 70
                        #background_normal: ''
                        pos_hint: {'center_x':0.5}
                        on_press:
                            root.generate_certificate()

                    Label:
                        size_hint: None, None
                Label:
                    size_hint: 1, None
                    height: 100




<OpeningWindow>:
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            pos: self.pos
            size: self.size
    Image:
        source: 'background_files/tech1.jpg'
        #size_hint: None,None
        size: self.size
        width: dp(1000)
        color: (1,1,1,0.7)
        allow_stretch: True
        keep_ratio: False
    GridLayout:
        spacing: 30
        padding: 40,30
        rows: 7
        GridLayout:
            cols: 2

            Image:
                source:'LOGO-TECH PROGRAM.jpg'
                size_hint:None,None
                height: dp(180)
                width: dp(180)
            Label:
                text: 'LE FORM  VENTURA  GLOBAL LLP'
                color:0,0,0,0.5
                bold: True
                font_size:50
        Label:
            size_hint: None,None
            height: dp(500)
    BoxLayout:
        spacing: 50
        orientation: 'vertical'
        MDFillRoundFlatIconButton:
            text: 'New Share Holder'
            font_size: 30
            bold: True
            size_hint: 0.75,None
            height: dp(60)
            #md_bg_color: (1,165/255,0,1)
            icon: 'account-multiple-plus-outline'
            pos_hint: {'center_x': 0.5}
            on_press:
                root.manager.current = 'RegistrationWindow'
                root.manager.transition.direction = 'left'
        MDFillRoundFlatIconButton:
            text: 'View Existing Share Holder'
            font_size: 30
            icon: 'account-eye'
            #md_bg_color: (1,165/255,0,1)
            bold: True
            size_hint: 0.75,None
            height: dp(60)
            pos_hint: {'center_x': 0.5}
            on_press:
                root.manager.current = 'SearchWindow'
                root.manager.transition.direction = 'left'
                root.set_call_page(False)
        MDFillRoundFlatIconButton:
            text: 'Total ShareHolders'
            font_size: 30
            icon: 'account-group-outline'
            #md_bg_color: (1,165/255,0,1)
            bold: True
            size_hint: 0.75,None
            height: dp(60)
            pos_hint: {'center_x': 0.5}
            on_press:
                root.total_shareholders()
        MDFillRoundFlatIconButton:
            text: 'Administrative Page'
            font_size: 30
            icon: 'account-network-outline'
            #md_bg_color: (1,165/255,0,1)
            bold: True
            size_hint: 0.75,None
            height: dp(60)
            pos_hint: {'center_x': 0.5}
            on_press:
                root.ask_admin_password()

        Label:
            size_hint: 1,None
            height: dp(1)

<SearchWindow>:
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            pos: self.pos
            size: self.size
    Image:
        source: 'background_files/hologram1.jpg'
        #size_hint: None,None
        size: self.size
        width: dp(1000)
        color: (1,1,1,0.7)
        allow_stretch: True
        keep_ratio: False
    GridLayout:
        spacing: 30
        padding: 40,10
        cols:1
        GridLayout:
            cols: 2

            Image:
                source:'LOGO-TECH PROGRAM.jpg'
                size_hint:None,None
                height: dp(180)
                width: dp(180)
            Label:
                text: 'LE FORM  VENTURA  GLOBAL LLP'
                color:0,0,0,0.7
                bold: True
                font_size:50

        Label:
            size_hint: None, None
        MDFillRoundFlatIconButton:
            text: 'Back'
            size_hint:None, None
            icon: 'arrow-left-circle'
            height: dp(40)
            width: dp(100)
            #background_color: 1, 165/255, 0, 0.2
            color: 1, 168/255, 0, 1
            #background_normal: ''
            on_press:
                root.manager.current = 'OpeningWindow'
                root.manager.transition.direction = 'right'
        Label:
            text: 'About Existing Registration'
            color: 0,0,0,1
            font_size: dp(25)
            bold: True
            size_hint: 1,None


            canvas.before:
                Color:
                    rgba: 1,165/255,0,1
                Line:

                    width: 5
                    rectangle: self.x, self.y, self.width, self.height
        GridLayout:
            cols:3
            Label:
                size_hint: None,None
                width: dp(200)
            MDTextField:
                id: registration_no
                text: ''
                hint_text: 'Registration No'
                mode: 'fill'
                max_text_length: 4
                fill_color_normal: 0.9,0.9,0.9,1
                size_hint: 0.5, None
                height: dp(55)
                multiline: False
                on_text:
                    self.text = self.text.replace(' ','')
            Label:
                size_hint: None,None
                width: dp(200)
        GridLayout:
            cols:3

            MDFillRoundFlatIconButton:
                text: 'Search'
                size_hint:1, None
                icon: 'account-search'
                height: dp(40)
                width: dp(100)
                #background_color: 1, 165/255, 0, 0.2
                md_bg_color: 1, 168/255, 0, 1
                #background_normal: ''
                on_press:
                    #root.manager.current = 'EditingWindow'
                    root.get_registration_no()

            Label:
                size_hint: None, None


            MDFillRoundFlatIconButton:
                text: 'Delete'
                size_hint:1, None
                icon: 'delete'
                height: dp(40)
                width: dp(100)
                #background_color: 1, 165/255, 0, 0.2
                md_bg_color: 1, 168/255, 0, 1
                #background_normal: ''
                on_press:
                    #root.manager.current = 'EditingWindow'
                    root.delete()

        Label:
            size_hint: 1, None
            height: 100


<EditingWindow>:
    GridLayout:
        cols: 1
        BoxLayout:
            size_hint: 1,None
            height: dp(180)
            canvas.before:
                Color:
                    rgba: 1, 1, 1, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
                    source: 'background_files/white.jpg'
            Image:
                source:'LOGO-TECH PROGRAM.png'
                size_hint:None,None
                height: dp(180)
                width: dp(180)
            Label:
                text: 'LE FORM  VENTURA  GLOBAL LLP'
                color:0,0,0,0.7
                bold: True
                font_size:50

        ScrollView:
            id: scroll_view_edit
            canvas.before:
                Color:
                    rgba: 1, 1, 1, 0.7
                Rectangle:
                    pos: self.pos
                    size: self.size
                    source: 'background_files/tech.jpg'

            GridLayout:
                size_hint: 1, None
                height: self.minimum_height
                cols:1
                spacing: 70
                padding:40,30
                GridLayout:
                    cols: 1
                    MDFillRoundFlatIconButton:
                        text: 'Back'
                        size_hint:None, None
                        icon: 'arrow-left-circle'
                        height: dp(40)
                        width: dp(100)
                        #background_color: 1, 165/255, 0, 0.2
                        color: 1, 168/255, 0, 1
                        #background_normal: ''
                        on_press:
                            root.manager.current = 'OpeningWindow'
                            root.manager.transition.direction = 'right'
                            root.parent.get_screen('SearchWindow').ids.registration_no.text = ''
                Label:
                    text: 'EDIT SHAREHOLDER DETAILS'
                    color: 0,0,0,1
                    font_size: dp(25)
                    bold: True
                    size_hint: 1,None
                    height: dp(70)


                Label:
                    text: 'Section 1: SHAREHOLDER DETAILS'
                    color: 0,0,0,1
                    font_size: dp(20)
                    size_hint: 0.5,None
                    height: dp(1)
                    bold: True


                MDTextField:
                    id: first_name
                    hint_text: 'First Name'
                    mode: 'fill'
                    max_text_length: 30
                    fill_color_normal: 1,1,1,1
                    on_focus:
                        self.required = True
                    text: ''
                    size_hint: 0.5, None
                    height: dp(55)
                    background_color: 255/255,163/255,0,0.2
                    multiline: False


                MDTextField:
                    id: surname
                    hint_text: 'Surname/Family name'
                    mode: 'fill'
                    max_text_length: 30
                    fill_color_normal: 1,1,1,1
                    on_focus:
                        self.required = True
                    text: ''
                    size_hint: 0.5, None
                    height: dp(55)
                    background_color: 255/255,163/255,0,0.2
                    multiline: False

                Label:
                    text: 'Gender:'
                    color: 0,0,0,1
                    font_size: dp(19)
                    size_hint: 0.5, None
                    height:dp(1)
                    bold: True
                GridLayout:
                    cols: 5
                    Label:
                        size_hint: None,None
                        width: dp(480)
                    Label:
                        text: 'Male:'
                        color: 0,0,0,1
                        font_size: dp(16)
                        size_hint: None, None
                        #height:dp(1)
                        bold: True
                    MDCheckbox:
                        id: male_checkbox
                        size_hint: None,None
                        on_press: root.male_checkbox(self)
                    Label:
                        text: 'Female:'
                        color: 0,0,0,1
                        font_size: dp(16)
                        size_hint: None, None
                        #height:dp(1)
                        bold: True
                    MDCheckbox:
                        id: female_checkbox
                        size_hint: None,None
                        on_press: root.female_checkbox(self)
                Label:
                    size_hint: 1,None
                    height: dp(20)


                MDTextField:
                    id: date_of_birth
                    hint_text: 'Date of Birth'
                    mode: 'fill'
                    max_text_length: 10
                    fill_color_normal: 1,1,1,1
                    on_focus:
                        self.required = True
                    text: ''
                    size_hint: 0.5, None
                    height: dp(55)
                    background_color: 255/255,163/255,0,0.2
                    multiline: False
                    on_text: self.text = self.text.replace(' ','')
                    helper_text: 'DD/MM/YYYY'
                    validator: 'date'
                    date_format: 'dd/mm/yyyy'
                    date_interval: "01/01/1900", None

                MDTextField:
                    id: postal_address
                    hint_text: 'Postal Address'
                    text: ''
                    mode: 'fill'
                    max_text_length: 120
                    fill_color_normal: 1,1,1,1
                    on_focus:
                        self.required = True
                    size_hint: 0.5, None
                    height: dp(55)
                    multiline: False

                MDTextField:
                    id: post_code
                    hint_text: 'Post Code'
                    mode: 'fill'
                    max_text_length: 120
                    fill_color_normal: 1,1,1,1
                    on_focus:
                        self.required = True
                    size_hint: 0.5, None
                    height: dp(55)
                    multiline: False
                    on_text: self.text = self.text.replace(' ','')

                Label:
                    text: 'Mobile phone no:'
                    color: 0,0,0,1
                    bold: True
                    font_size: dp(19)
                    size_hint: 0.5, None
                    height:dp(1)



                GridLayout:
                    cols: 3
                    MDTextField:
                        id: mobile_phone_no_india
                        hint_text: 'India'
                        mode: 'fill'
                        max_text_length: 13
                        helper_text: 'Eg: +910123456789'
                        fill_color_normal: 1,1,1,1
                        on_focus:
                            self.required = True
                        size_hint: 0.5, None
                        height: dp(55)
                        multiline: False
                        on_text: self.text = self.text.replace(' ','')
                    Label:
                        size_hint: None,None
                    MDTextField:
                        id: mobile_phone_no_abroad
                        hint_text: 'Work Place'
                        mode: 'fill'
                        max_text_length: 15
                        helper_text: 'Eg: +(Country Code)0123456789'
                        fill_color_normal: 1,1,1,1
                        on_focus:
                            self.required = True
                        size_hint: 0.5, None
                        height: dp(55)
                        multiline: False
                        on_text: self.text = self.text.replace(' ','')
